# AI Banking Bot - Environment Configuration

# ============================================
# DATABASE
# ============================================
MONGODB_URI=mongodb://localhost:27017/ai-banking-bot
MONGODB_USER=
MONGODB_PASSWORD=

# ============================================
# SERVER
# ============================================
NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:5173

# ============================================
# SECURITY & AUTHENTICATION
# ============================================
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRE=7d
BCRYPT_ROUNDS=10

# ============================================
# AI & LLM (OLLAMA - Local)
# ============================================
OLLAMA_BASE=http://localhost:11434
OLLAMA_MODEL=mistral
# Supported models: mistral, llama2, neural-chat, orca-mini

# ============================================
# VECTOR DATABASE (CHROMA)
# ============================================
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=banking_docs

# ============================================
# FILE UPLOADS
# ============================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,txt,docx

# ============================================
# API RATE LIMITING
# ============================================
RATE_LIMIT_MAX_REQUESTS=20
RATE_LIMIT_WINDOW_MS=900000

# ============================================
# LOGGING & AUDIT
# ============================================
LOG_LEVEL=debug
AUDIT_LOG_ENABLED=true
AUDIT_LOG_DIR=./logs

# ============================================
# OPTIONAL: Third-party APIs
# ============================================
# If you want to use cloud LLMs instead of local Ollama
# OPENAI_API_KEY=sk-...
# HUGGINGFACE_API_KEY=hf_...

# ============================================
# DEVELOPMENT ONLY
# ============================================
DEBUG=ai-banking-bot:*
SEED_DB=true
